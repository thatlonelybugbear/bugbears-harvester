<section class="tab bugbears-harvester-results-tab{{#if tab.active}} active{{/if}}" data-group="{{tab.group}}" data-tab="{{tab.id}}">
    <table class="flexcol bugbears-harvester-results-table" data-results>
        <thead>
            <tr class="flexrow">
                <th class="image flexrow">
                    <button class="inline-control icon fa-solid fa-plus" data-action="createResult"
                            data-tooltip aria-label="{{localize "TABLE.ACTIONS.CreateResult"}}"></button>
                </th>
                <th class="details flexrow">{{localize "TABLE_RESULT.Details"}}</th>
                {{#if isHarvestTable}}
                <th class="harvester bugbears-harvester-bulk-skill flexcol">
                    <span>{{localize "BBH.RESULTS.Skill"}}</span>
                    <span class="bugbears-harvester-bulk-skill-controls">
                        <select data-harvester-bulk-skill aria-label="{{localize "BBH.RESULTS.ApplySkillToAllAria"}}">
                            <option value=""></option>
                            {{#each harvestBulkSkillOptions}}
                            <option value="{{this.value}}">{{this.label}}</option>
                            {{/each}}
                        </select>
                        <button type="button" class="inline-control icon fa-solid fa-check" data-action="applySkillToAll"
                                data-tooltip aria-label="{{localize "BBH.RESULTS.ApplySelectedSkillToAllAria"}}"></button>
                    </span>
                </th>
                <th class="harvester flexrow">{{localize "BBH.RESULTS.Dc"}}</th>
                {{/if}}
                {{#if hasQuantityColumn}}
                <th class="harvester flexrow">{{localize "BBH.RESULTS.Quantity"}}</th>
                {{/if}}
                <th class="weight flexrow">{{localize "TABLE_RESULT.FIELDS.weight.label"}}</th>
                <th class="range flexrow">{{localize "TABLE_RESULT.FIELDS.range.label"}}</th>
                <th class="controls flexrow">
                    <button class="inline-control icon fa-solid fa-scale-balanced" data-action="normalizeResults"
                        data-tooltip aria-label="{{localize "TABLE.ACTIONS.NormalizeResults"}}"></button>
                </th>
            </tr>
        </thead>
        <tbody class="scrollable">
            {{#each results as |result i|}}
            <tr class="flexrow{{#if result.drawn}} drawn{{/if}}" data-result-id="{{result.id}}">
                <td class="image flexrow">
                    <img src="{{result.img}}" data-action="editImage" data-edit="results.{{i}}.img"
                         alt="{{localize "TABLE_RESULT.FIELDS.img.label"}}" loading="lazy">
                </td>

                <td class="details">
                    {{> "templates/sheets/roll-table/result-details.hbs" result=result}}
                </td>

                {{#if ../isHarvestTable}}
                <td class="harvester flexrow">
                    <select name="results.{{i}}.flags.bbh.skill">
                        <option value=""></option>
                        {{#each result.harvestSkillOptions}}
                        <option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
                        {{/each}}
                    </select>
                </td>

                <td class="harvester flexrow">
                    <input type="number" min="0" step="1" name="results.{{i}}.flags.bbh.dc"
                           value="{{result.harvestDc}}" placeholder="{{localize "BBH.RESULT_CONFIG.DcPlaceholder"}}">
                </td>
                {{/if}}

                {{#if ../hasQuantityColumn}}
                <td class="harvester flexrow">
                    <input type="text" name="results.{{i}}.flags.bbh.quantity"
                           value="{{result.harvestQuantity}}" placeholder="{{localize "BBH.RESULT_CONFIG.QuantityPlaceholder"}}">
                </td>
                {{/if}}

                <td class="weight flexrow">
                    <input type="number" name="results.{{i}}.weight" value="{{result.weight}}" placeholder="{{localize "BBH.COMMON.One"}}">
                </td>

                <td class="range flexrow">
                    <input type="number" name="results.{{i}}.range.0" value="{{result.range.[0]}}" placeholder="{{localize "BBH.COMMON.RangeLow"}}">
                    <span class="dash">-</span>
                    <input type="number" name="results.{{i}}.range.1" value="{{result.range.[1]}}" placeholder="{{localize "BBH.COMMON.RangeHigh"}}">
                </td>

                <td class="controls flexrow">
                    <button class="inline-control icon fa-solid fa-file-pen" data-action="openResultSheet"
                            data-tooltip aria-label="{{localize "TABLE.ACTIONS.OpenResultConfig"}}"></button>
                    <button class="inline-control icon fa-solid fa-lock{{#unless result.drawn}}-open{{/unless}}"
                            data-action="lockResult"
                            data-tooltip aria-label="{{localize "TABLE.ACTIONS.ToggleDrawn"}}"></button>
                    <button class="inline-control icon fa-solid fa-trash" data-action="deleteResult"
                            data-tooltip aria-label="{{localize "TABLE.ACTIONS.DeleteResult"}}"></button>
                </td>

                <input type="hidden" name="results.{{i}}._id" value="{{result.id}}">
            </tr>
            {{/each}}
        </tbody>
    </table>
</section>
